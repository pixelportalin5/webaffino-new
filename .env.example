# Public site URL used for canonicals, sitemap, and Open Graph
NEXT_PUBLIC_SITE_URL=https://webaffino.com

# WordPress REST API base URL (headless CMS — use admin subdomain in production)
WORDPRESS_API_BASE=https://admin.webaffino.com/wp-json/wp/v2

# Where contact submissions are stored in WordPress:
# - forminator (default): Forminator → Submissions for form 6427
# - wordpress-table: custom wp_webaffino_contact_submissions table (requires mu-plugin)
CONTACT_STORAGE_MODE=forminator

# Forminator form used for WordPress storage
WORDPRESS_FORMINATOR_FORM_ID=6427

# Forminator field slugs (defaults match standard 4-field contact forms)
# FORMINATOR_FIELD_NAME=name-1
# FORMINATOR_FIELD_EMAIL=email-1
# FORMINATOR_FIELD_PHONE=phone-1
# FORMINATOR_FIELD_MESSAGE=textarea-1

# Optional custom table storage (when CONTACT_STORAGE_MODE=wordpress-table)
# Install wordpress-mu-plugins/webaffino-contact-submissions.php on WordPress first.
# WORDPRESS_CONTACT_STORAGE_URL=https://webaffino.com/wp-json/webaffino/v1/contact-submissions
# WORDPRESS_CONTACT_STORAGE_SECRET=

# Contact form notification email recipient
CONTACT_NOTIFICATION_EMAIL=affiliate@webaffino.com

# Optional: Resend API key for email notifications
# RESEND_API_KEY=

# Optional: verified sender for Resend (defaults to onboarding@resend.dev)
# CONTACT_NOTIFICATION_FROM=Web Affino <notifications@webaffino.com>

# Optional: webhook that receives { name, email, phone, message }
# CONTACT_WEBHOOK_URL=
